Package: svySE
Type: Package
Title: Sampling Error Estimation for Complex Surveys
Version: 0.3.0
Authors@R:
    person(
        given = "Luis",
        family = "Burgos",
        email = "lburgoss1996@gmail.com",
        role = c("aut", "cre"),
        comment = c(
            ORCID = "0009-0008-8290-4228"
        )
